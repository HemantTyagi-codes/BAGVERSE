<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BagVerse</title>

    <link
        href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css"
        rel="stylesheet">

    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="font-['helvetica_now_display'] pt-16">

<nav class="w-full fixed top-0 left-0 px-6 py-4 bg-white shadow flex justify-between items-center z-50">

    <% var loggedin = typeof loggedin !== "undefined" ? loggedin : true %>

    <h3 class="text-2xl font-semibold">
        BagVerse
    </h3>

    <% if(loggedin){ %>

        <div class="flex gap-6 items-center">

            <a
                class="hover:text-blue-500"
                href="/shop">
                Shop
            </a>

            <a
                class="hover:text-blue-500"
                href="/cart">
                Cart
            </a>

            <a
                class="hover:text-blue-500"
                href="/users/profile">
                My Account
            </a>

            <a
                class="text-red-600 hover:text-red-800"
                href="/users/logout">
                Logout
            </a>

        </div>

    <% } %>

</nav>