<%- include('./partials/header') %>

<div class="w-full min-h-screen flex items-start px-20 py-20">

    <!-- Sidebar -->
    <div class="w-[25%] flex flex-col items-start">

        <div class="flex flex-col">

            <a
                class="block w-fit mb-2 hover:text-blue-500"
                href="/shop">
                All Products
            </a>

            <a
                class="block w-fit mb-2 hover:text-blue-500"
                href="/owners/admin">
                Create New Product
            </a>

        </div>

    </div>

    <!-- Products -->
    <div class="w-[75%] flex flex-col gap-5">

        <a
            class="text-red-500 hover:text-red-700"
            href="/products/deleteall">

            Delete All Products

        </a>

        <div class="flex flex-wrap gap-5">

            <% if(products && products.length > 0){ %>

                <% products.forEach(function(product){ %>

                    <div
                        class="w-60 rounded-md overflow-hidden shadow">

                        <!-- Product Image -->
                        <div
                            class="w-full h-52 flex items-center justify-center"
                            style="background-color:<%= product.bgcolor %>">

                            <img
                                class="h-40 object-contain"
                                src="/images/uploads/<%= product.image %>"
                                alt="<%= product.name %>">

                        </div>

                        <!-- Product Info -->
                        <div
                            class="flex justify-between items-center px-4 py-4"
                            style="
                                background-color:<%= product.panelcolor %>;
                                color:<%= product.textcolor %>;
                            ">

                            <div>

                                <h3 class="font-semibold">
                                    <%= product.name %>
                                </h3>

                                <% if(product.discount > 0){ %>

                                    <h4>
                                        ₹ <%= product.price - product.discount %>
                                    </h4>

                                    <p class="line-through text-sm opacity-70">
                                        ₹ <%= product.price %>
                                    </p>

                                <% } else { %>

                                    <h4>
                                        ₹ <%= product.price %>
                                    </h4>

                                <% } %>

                            </div>

                            <a
                                href="/products/delete/<%= product._id %>"
                                class="w-8 h-8 flex items-center justify-center rounded-full bg-white text-red-500">

                                <i class="ri-delete-bin-line"></i>

                            </a>

                        </div>

                    </div>

                <% }) %>

            <% } else { %>

                <div class="w-full text-center">

                    <h2 class="text-2xl font-semibold">
                        No Products Found
                    </h2>

                </div>

            <% } %>

        </div>

    </div>

</div>

<%- include('./partials/footer') %>