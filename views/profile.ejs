<%- include('./partials/header') %>

<div class="w-full min-h-screen flex items-center justify-center bg-gray-100">

    <div class="bg-white shadow-md rounded-lg p-8 w-[400px] text-center">

        <h1 class="text-2xl font-bold mb-6">My Profile</h1>

        <!-- Profile Image (optional) -->
        <div class="flex justify-center mb-4">
            <div class="w-24 h-24 rounded-full bg-gray-300 flex items-center justify-center">
                <span class="text-2xl font-bold">
                    <%= user.fullname.charAt(0) %>
                </span>
            </div>
        </div>

        <div class="text-left space-y-3">

            <p>
                <span class="font-semibold">Name:</span>
                <%= user.fullname %>
            </p>

            <p>
                <span class="font-semibold">Email:</span>
                <%= user.email %>
            </p>

            <p><b>Contact:</b> <%= user.contact %></p>

        </div>

        <a href="/users/logout"
           class="mt-6 inline-block bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600">
            Logout
        </a>

    </div>

</div>

<%- include('./partials/footer') %>