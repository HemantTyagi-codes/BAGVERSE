<%- include('./partials/admin-header') %>

<div class="w-full min-h-screen flex items-start px-6 sm:px-10 py-10 bg-gray-50 antialiased">

    <div class="w-1/4 flex flex-col items-start pr-4 sticky top-10">
        <div class="flex flex-col space-y-3">
            <a class="block font-semibold text-gray-700 hover:text-blue-600 transition" href="/shop">
                🔍 View Live Shop
            </a>
            <a class="block font-bold text-blue-600 bg-blue-50 px-4 py-2 rounded-xl border border-blue-100" href="/owners/admin">
                ➕ Create New Product
            </a>
        </div>
    </div>

    <main class="w-3/4 bg-white border border-gray-200 p-8 shadow-sm rounded-2xl ml-4">

        <h2 class="text-2xl font-extrabold mb-6 text-gray-800 tracking-tight">
            Create New Product
        </h2>

        <form
            autocomplete="off"
            action="/products/create"
            method="POST"
            enctype="multipart/form-data"
            class="bg-gray-50 border border-gray-100 p-6 rounded-2xl shadow-inner space-y-4"
        >
            <h3 class="text-base font-bold text-gray-700 pb-2 border-b border-gray-200">
                Product Details
            </h3>

            <div>
                <label class="block mb-1.5 text-xs font-bold uppercase tracking-wider text-gray-500">
                    Product Image Asset
                </label>
                <input
                    required
                    name="image"
                    type="file"
                    accept="image/*"
                    class="w-full bg-white border border-gray-300 p-2.5 rounded-xl text-sm file:mr-4 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 transition"
                >
            </div>

            <div>
                <input
                    required
                    name="name"
                    type="text"
                    placeholder="Product Title / Model Name"
                    class="w-full bg-white border border-gray-300 p-2.5 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition shadow-sm"
                >
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <input
                        required
                        name="price"
                        type="number"
                        placeholder="Price (₹)"
                        class="w-full bg-white border border-gray-300 p-2.5 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition shadow-sm"
                    >
                </div>
                <div>
                    <input
                        name="discount"
                        type="number"
                        placeholder="Discount (₹)"
                        class="w-full bg-white border border-gray-300 p-2.5 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition shadow-sm"
                    >
                </div>
            </div>

            <div>
                <select
                    required
                    name="category"
                    class="w-full bg-white border border-gray-300 p-2.5 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition shadow-sm"
                >
                    <option value="">Select Target Category</option>
                    <option value="Travel">Travel Bag</option>
                    <option value="Premium">Premium Luxury</option>
                    <option value="Laptop">Laptop Backpack</option>
                    <option value="School">School Essentials</option>
                </select>
            </div>

            <button
                type="submit"
                class="w-full bg-blue-600 text-white py-3 rounded-xl font-bold hover:bg-blue-700 shadow transition"
            >
                🚀 Compile & Create Product
            </button>
        </form>

        <hr class="my-10 border-gray-200">

        <h2 class="text-2xl font-extrabold mb-6 text-gray-800 tracking-tight">
            Active Catalog Products
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 items-stretch">
            <% if (products && products.length > 0) { %>
                <% products.forEach(function(product){ %>
                    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden flex flex-col justify-between hover:shadow-md transition duration-200">
                        <div>
                            <div class="w-full h-44 bg-gray-50 flex items-center justify-center p-4 overflow-hidden relative">
                                <img
                                    src="/images/<%= product.image %>"
                                    alt="<%= product.name %>"
                                    class="max-w-full max-h-full object-contain block"
                                >
                            </div>

                            <div class="p-4">
                                <h3 class="text-sm font-bold text-gray-800 mb-2 line-clamp-1">
                                    <%= product.name %>
                                </h3>
                                <div class="space-y-1">
                                    <p class="text-xs font-semibold text-gray-600">
                                        💰 Price: <span class="text-gray-900 font-bold">₹<%= product.price %></span>
                                    </p>
                                    <p class="text-xs font-medium text-gray-400">
                                        🎯 Deducted: ₹<%= product.discount || 0 %>
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="p-4 pt-0 flex gap-2">
                            <a
                                href="/products/edit/<%= product._id %>"
                                class="flex-1 text-center bg-amber-400 hover:bg-amber-500 text-gray-900 py-2 rounded-xl text-xs font-bold shadow-sm transition"
                            >
                                ✏️ Edit
                            </a>
                            <a
                                href="/products/delete/<%= product._id %>"
                                onclick="return confirm('Delete this product?')"
                                class="flex-1 text-center bg-red-500 hover:bg-red-600 text-white py-2 rounded-xl text-xs font-bold shadow-sm transition"
                            >
                                🗑 Delete
                            </a>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-full text-center py-12 bg-gray-50 rounded-2xl border border-dashed border-gray-200">
                    <p class="text-sm text-gray-400 font-medium">No inventory elements created yet.</p>
                </div>
            <% } %>
        </div>

    </main>

</div>

<%- include('./partials/footer') %>