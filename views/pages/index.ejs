<%- include('../partials/header') %>

<% if (error && error.length > 0) { %>
    <div class="fixed top-20 left-1/2 z-50 w-[calc(100%-2rem)] max-w-md -translate-x-1/2 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700 shadow-sm">
        <%= error[0] %>
    </div>
<% } %>

<% if (success && success.length > 0) { %>
    <div class="fixed top-20 left-1/2 z-50 w-[calc(100%-2rem)] max-w-md -translate-x-1/2 rounded-md border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700 shadow-sm">
        <%= success[0] %>
    </div>
<% } %>

<main class="min-h-[calc(100vh-4rem)] bg-[#f7f7f5] px-5 py-8 text-zinc-950 md:px-10 lg:px-16">
    <section class="mx-auto grid min-h-[calc(100vh-8rem)] max-w-6xl overflow-hidden rounded-lg border border-zinc-200 bg-white shadow-sm lg:grid-cols-[1.05fr_0.95fr]">

        <div class="flex items-center px-6 py-10 sm:px-10 lg:px-14">
            <div class="w-full max-w-md">
                <p class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-blue-600">
                    BagVerse
                </p>

                <h1 class="text-3xl font-semibold leading-tight text-zinc-950 sm:text-4xl">
                    Create your account
                </h1>

                <p class="mt-3 max-w-sm text-sm leading-6 text-zinc-500">
                    Sign up to explore curated bags, save your cart, and manage your profile.
                </p>

                <form class="mt-8 space-y-4" autocomplete="off" action="/users/register" method="POST">
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-zinc-700" for="fullname">
                            Full name
                        </label>
                        <input
                            id="fullname"
                            required
                            class="block w-full rounded-md border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm outline-none transition focus:border-zinc-900 focus:bg-white focus:ring-2 focus:ring-zinc-900/10"
                            type="text"
                            placeholder="Your name"
                            name="fullname">
                    </div>

                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-zinc-700" for="register-email">
                            Email
                        </label>
                        <input
                            id="register-email"
                            required
                            class="block w-full rounded-md border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm outline-none transition focus:border-zinc-900 focus:bg-white focus:ring-2 focus:ring-zinc-900/10"
                            type="email"
                            placeholder="you@example.com"
                            name="email">
                    </div>

                    <div class="grid gap-4 sm:grid-cols-2">
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-zinc-700" for="register-password">
                                Password
                            </label>
                            <input
                                id="register-password"
                                required
                                class="block w-full rounded-md border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm outline-none transition focus:border-zinc-900 focus:bg-white focus:ring-2 focus:ring-zinc-900/10"
                                type="password"
                                placeholder="Password"
                                name="password">
                        </div>

                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-zinc-700" for="contact">
                                Contact
                            </label>
                            <input
                                id="contact"
                                type="number"
                                name="contact"
                                placeholder="Phone number"
                                required
                                class="no-spinner block w-full rounded-md border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm outline-none transition focus:border-zinc-900 focus:bg-white focus:ring-2 focus:ring-zinc-900/10">
                        </div>
                    </div>

                    <button
                        class="inline-flex w-full items-center justify-center gap-2 rounded-md bg-zinc-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-zinc-800"
                        type="submit">
                        Create account
                        <i class="ri-arrow-right-line text-base"></i>
                    </button>
                </form>
            </div>
        </div>

        <div class="border-t border-zinc-200 bg-zinc-100 px-6 py-10 text-zinc-950 sm:px-10 lg:flex lg:items-center lg:border-l lg:border-t-0 lg:px-14">
            <div class="w-full max-w-md">
                <p class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-blue-600">
                    Welcome back
                </p>

                <h2 class="text-3xl font-semibold leading-tight">
                    Login to continue
                </h2>

                <p class="mt-3 text-sm leading-6 text-zinc-500">
                    Access your cart and continue shopping from where you left off.
                </p>

                <form class="mt-8 space-y-4" autocomplete="off" action="/users/login" method="POST">
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-zinc-700" for="login-email">
                            Email
                        </label>
                        <input
                            id="login-email"
                            required
                            class="block w-full rounded-md border border-zinc-200 bg-white px-4 py-3 text-sm text-zinc-950 outline-none transition placeholder:text-zinc-400 focus:border-zinc-900 focus:bg-white focus:ring-2 focus:ring-zinc-900/10"
                            type="email"
                            placeholder="you@example.com"
                            name="email">
                    </div>

                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-zinc-700" for="login-password">
                            Password
                        </label>
                        <input
                            id="login-password"
                            required
                            class="block w-full rounded-md border border-zinc-200 bg-white px-4 py-3 text-sm text-zinc-950 outline-none transition placeholder:text-zinc-400 focus:border-zinc-900 focus:bg-white focus:ring-2 focus:ring-zinc-900/10"
                            type="password"
                            placeholder="Password"
                            name="password">
                    </div>

                    <button
                        class="inline-flex w-full items-center justify-center gap-2 rounded-md bg-blue-500 px-5 py-3 text-sm font-semibold text-white transition hover:bg-blue-400"
                        type="submit">
                        Login
                        <i class="ri-login-circle-line text-base"></i>
                    </button>
                </form>
            </div>
        </div>

    </section>
</main>

<%- include('../partials/footer') %>

