<%- include('../partials/header') %>

<% if (error && error.length > 0) { %>
    <div class="absolute top-5 left-1/2 -translate-x-1/2 p-3 rounded-md bg-red-500 shadow-lg">
        <span class="text-white font-medium">
            <%= error[0] %>
        </span>
    </div>
<% } %>

<% if (success && success.length > 0) { %>
    <div class="absolute top-5 left-1/2 -translate-x-1/2 p-3 rounded-md bg-green-500 shadow-lg">
        <span class="text-white font-medium">
            <%= success[0] %>
        </span>
    </div>
<% } %>

<div class="w-full h-screen flex px-20">

    <!-- Register Section -->
    <div class="w-1/2 flex items-center justify-center h-screen">
        <div class="w-full px-32">

            <h3 class="text-4xl">
                Welcome to
                <span class="text-blue-400 font-semibold">
                    Scatch
                </span>
            </h3>

            <h4 class="text-2xl mb-5">
                Create your account
            </h4>

            <form autocomplete="off" action="/users/register" method="POST">

                <input
                    required
                    class="bg-zinc-100 block w-full px-3 py-2 border rounded-md mb-3 border-zinc-200"
                    type="text"
                    placeholder="Full Name"
                    name="fullname">

                <input
                    required
                    class="bg-zinc-100 block w-full px-3 py-2 border rounded-md mb-3 border-zinc-200"
                    type="email"
                    placeholder="Email"
                    name="email">

                <input
                    required
                    class="bg-zinc-100 block w-full px-3 py-2 border rounded-md mb-3 border-zinc-200"
                    type="password"
                    placeholder="Password"
                    name="password">


                 <input
                    type="number"
                     name="contact"
                      placeholder="Contact Number"
                       required
                       class="border p-2 rounded w-full mb-3 no-spinner"
                       />

                <input
                    class="px-5 rounded-full py-3 mt-2 bg-blue-500 text-white cursor-pointer hover:bg-blue-600"
                    type="submit"
                    value="Create My Account">

            </form>

        </div>
    </div>

    <!-- Login Section -->
    <div class="w-1/2 flex items-center justify-center h-screen">
        <div class="w-full px-32">

            <h4 class="text-2xl capitalize mb-5">
                Login to your account
            </h4>

            <form autocomplete="off" action="/users/login" method="POST">

                <input
                    required
                    class="block bg-zinc-100 w-full px-3 py-2 border rounded-md mb-3 border-zinc-200"
                    type="email"
                    placeholder="Email"
                    name="email">

                <input
                    required
                    class="block bg-zinc-100 w-full px-3 py-2 border rounded-md mb-3 border-zinc-200"
                    type="password"
                    placeholder="Password"
                    name="password">

                <input
                    class="px-5 block rounded-full py-3 mt-2 bg-blue-500 text-white cursor-pointer hover:bg-blue-600"
                    type="submit"
                    value="Login">

            </form>

        </div>
    </div>

</div>

<%- include('../partials/footer') %>

