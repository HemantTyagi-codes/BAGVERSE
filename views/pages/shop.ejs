<% if(success && success.length > 0){ %>
<div class="fixed top-6 left-1/2 -translate-x-1/2 bg-gray-900/95 backdrop-blur-md text-white px-6 py-3.5 rounded-2xl shadow-2xl z-50 border border-white/10 flex items-center gap-3 animate-bounce">
    <span class="text-green-400">✨</span>
    <span class="text-sm font-semibold tracking-wide"><%= success[0] %></span>
</div>
<% } %>

<%- include('../partials/header') %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 antialiased bg-gray-50/50 min-h-screen">

    <!-- HERO PROFILE SECTOR WITH INTEGRATED SEARCH -->
    <div class="relative bg-gradient-to-br from-amber-800 via-amber-900 to-orange-700 text-white rounded-[2.5rem] p-8 sm:p-12 mb-10 shadow-xl shadow-amber-900/10 overflow-hidden group flex flex-col md:flex-row md:items-center justify-between gap-8">
        <div class="absolute -right-10 -bottom-10 w-60 h-60 bg-white/5 rounded-full blur-3xl group-hover:bg-white/10 transition-all duration-700"></div>
        
        <div class="relative z-10 max-w-xl">
            <span class="inline-block bg-white/10 backdrop-blur-md text-amber-200 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-4">
                Premium Collections
            </span>
            <h1 class="text-4xl sm:text-5xl font-black tracking-tight leading-none">
                Find Your Perfect Bag
            </h1>
            <p class="mt-4 text-base text-amber-100/90 font-medium max-w-sm">
                Explore premium, resilient gear tailored for travel, modern executive spaces, and campus life.
            </p>
        </div>

        <!-- INTEGRATED SEARCH BAR PLATFORM -->
        <div class="relative z-10 w-full md:w-80 lg:w-[26rem] shrink-0">
            <form action="/shop" method="GET">
                <div class="flex bg-white/10 backdrop-blur-md p-2 rounded-2xl border border-white/20 focus-within:ring-2 focus-within:ring-white/40 focus-within:bg-white transition-all duration-300 group/search">
                    <div class="flex-1 flex items-center pl-3">
                        <span class="text-amber-200 group-focus-within/search:text-gray-400 transition-colors mr-2">🔍</span>
                        <input
                            type="text"
                            name="search"
                            placeholder="Search premium bags..."
                            class="w-full bg-transparent border-0 text-sm font-medium text-white placeholder-white/60 focus:text-gray-900 focus:placeholder-gray-400 focus:outline-none"
                        >
                    </div>
                    <button class="bg-white text-amber-900 hover:bg-amber-50 px-5 py-3 rounded-xl font-bold text-sm shadow-sm transition duration-150 transform active:scale-95">
                        Search
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- CORE COLUMN SPLIT -->
    <div class="flex flex-col lg:flex-row gap-8 items-start">

        <!-- ADVANCED DISCOVERY NAVIGATION FILTERS -->
        <div class="w-full lg:w-72 bg-white border border-gray-200/80 rounded-3xl shadow-md p-6 lg:sticky lg:top-6 transition-all">
            <div class="flex items-center justify-between mb-6 pb-3 border-b border-gray-100">
                <h2 class="text-base font-bold text-gray-900 flex items-center gap-2">
                    <span>🎛️</span> Filters
                </h2>
                <a href="/shop" class="text-xs font-semibold text-amber-700 hover:text-amber-800 transition">Clear All</a>
            </div>

            <form action="/shop" method="GET" class="space-y-6">
                <!-- CATEGORY BLOCK -->
                <div>
                    <h3 class="font-bold text-xs uppercase tracking-wider text-gray-400 mb-3">Category</h3>
                    <div class="space-y-2.5">
                        <% ['Travel', 'Premium', 'Laptop', 'School'].forEach(function(cat) { %>
                            <label class="flex items-center gap-3 text-sm font-medium text-gray-600 cursor-pointer group hover:text-gray-900">
                                <input type="radio" name="category" value="<%= cat %>" class="w-4 h-4 accent-amber-700 border-gray-300 rounded focus:ring-amber-500">
                                <span class="transition-colors"><%= cat %></span>
                            </label>
                        <% }) %>
                    </div>
                </div>

                <!-- PRICE BLOCK -->
                <div>
                    <h3 class="font-bold text-xs uppercase tracking-wider text-gray-400 mb-3">Price Bracket</h3>
                    <select name="price" class="border border-gray-200 rounded-xl p-2.5 w-full text-sm bg-gray-50 focus:outline-none focus:ring-2 focus:ring-amber-600/20 focus:border-amber-600 transition font-medium text-gray-700">
                        <option value="">All Price Limits</option>
                        <option value="1000">Under ₹1000</option>
                        <option value="2000">₹1000 - ₹2000</option>
                        <option value="5000">₹2000 - ₹5000</option>
                    </select>
                </div>

                <button class="w-full bg-amber-800 hover:bg-amber-900 text-white py-3 rounded-xl font-bold text-sm shadow-md shadow-amber-900/10 transition duration-150 transform active:scale-95">
                    Apply Filters
                </button>
            </form>
        </div>

        <!-- ACTIVE DISPLAY BOARD PLATFORM -->
        <div class="flex-1 w-full">
            <% if(products && products.length > 0){ %>
                <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6 items-stretch">
                    <% products.forEach(function(product){ %>
                        
                        <!-- HIGH RESOLUTION STORE PRODUCT CARD -->
                        <div class="group bg-white rounded-[2rem] overflow-hidden border border-gray-200/60 shadow-md hover:shadow-2xl hover:scale-[1.02] transition-all duration-300 flex flex-col justify-between relative">
                            
                            <!-- FLASH DISCOUNT METRIC BADGE -->
                            <% if(product.discount > 0){ %>
                                <span class="absolute top-4 left-4 bg-red-500/90 backdrop-blur-md text-white px-3 py-1 rounded-full text-xs font-black tracking-wider shadow-lg shadow-red-500/20 z-10 uppercase">
                                    <%= Math.round((product.discount/product.price)*100) %>% OFF
                                </span>
                            <% } %>

                            <div class="flex flex-col flex-1">
                                <!-- RESPONSIVE PROTECTED ASPECT RATIO IMAGE BAY -->
                                <div class="h-64 flex items-center justify-center p-8 overflow-hidden relative transition-colors duration-300" style="background-color: <%= product.bgcolor || '#fafafa' %>">
                                    <div class="absolute inset-0 bg-gradient-to-t from-black/[0.02] to-transparent pointer-events-none"></div>
                                    <img
                                        src="/images/<%= product.image %>"
                                        alt="<%= product.name %>"
                                        class="max-w-full max-h-44 object-contain group-hover:scale-110 transition-transform duration-500 ease-out drop-shadow-xl"
                                    >
                                </div>

                                <!-- PRODUCT ANALYTIC DETAIL PANEL -->
                                <div class="p-6 flex flex-col flex-1 justify-between transition-colors duration-200" style="background-color: <%= product.panelcolor %>; color: <%= product.textcolor %>;">
                                    <div>
                                        <h3 class="font-extrabold text-lg tracking-tight line-clamp-1 opacity-90 group-hover:opacity-100 transition-opacity">
                                            <%= product.name %>
                                        </h3>

                                        <% if(product.discount > 0){ %>
                                            <div class="flex items-baseline gap-2.5 mt-2.5">
                                                <span class="text-2xl font-black tracking-tight">
                                                    ₹<%= product.price - product.discount %>
                                                </span>
                                                <span class="line-through text-xs font-bold opacity-50 tracking-wide">
                                                    ₹<%= product.price %>
                                                </span>
                                            </div>
                                        <% } else { %>
                                            <div class="text-2xl font-black tracking-tight mt-2.5">
                                                ₹<%= product.price %>
                                            </div>
                                        <% } %>
                                    </div>

                                    <a
                                        href="/addtocart/<%= product._id %>"
                                        class="block text-center mt-6 bg-amber-800 hover:bg-amber-900 text-white py-3 rounded-2xl text-sm font-bold shadow-md hover:shadow-lg transition-all duration-150 active:scale-95 transform"
                                        style="background-color: <%= product.textcolor ? 'transparent' : '' %>; border: <%= product.textcolor ? '2px solid currentColor' : '' %>; color: <%= product.textcolor %>"
                                    >
                                        Add To Cart
                                    </a>
                                </div>
                            </div>

                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <!-- BEAUTIFIED ZERO INVENTORY BLANK VIEWCASE -->
                <div class="text-center w-full py-20 bg-white border border-dashed border-gray-200 rounded-[2.5rem] shadow-sm flex flex-col items-center justify-center max-w-xl mx-auto">
                    <div class="w-16 h-16 bg-amber-50 rounded-2xl flex items-center justify-center text-2xl mb-4">💼</div>
                    <h2 class="text-xl font-bold text-gray-900">No Premium Models Found</h2>
                    <p class="text-sm text-gray-400 mt-1 max-w-xs mx-auto">
                        We couldn't find matches matching those filter constraints. Try adjusting parameters or keyword search scopes.
                    </p>
                    <a href="/shop" class="mt-5 inline-block bg-gray-900 text-white text-xs font-bold px-4 py-2.5 rounded-xl hover:bg-gray-800 transition">Reset Search Metrics</a>
                </div>
            <% } %>
        </div>

    </div>
</div>

<%- include('../partials/footer') %>
