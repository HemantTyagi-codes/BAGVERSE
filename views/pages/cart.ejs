<%- include('../partials/header') %>

<div class="w-full min-h-screen px-20 py-10">

    <div class="flex items-start gap-10">


        <% if(user.cart && user.cart.length > 0){ %>


        <!-- Cart Items -->
        <div class="w-[60%]">

            <h2 class="text-2xl font-semibold mb-5">
                Shopping Cart
            </h2>


            <% user.cart.forEach(function(product){ %>


            <div class="border rounded-lg mb-5 overflow-hidden shadow">

                <div class="flex items-center p-5 gap-5">


                    <div
                        class="w-40 h-40 flex items-center justify-center"
                        style="background-color:<%= product.bgcolor %>">


                        <img
                            class="h-32 object-contain"
                            src="/images/<%= product.image %>"
                            alt="<%= product.name %>">


                    </div>


                    <div class="flex-1">


                        <h3 class="text-xl font-semibold">
                            <%= product.name %>
                        </h3>


                        <% if(product.discount > 0){ %>


                            <h4 class="text-lg font-semibold">
                                ₹ <%= product.price - product.discount %>
                            </h4>


                            <p class="line-through text-gray-500">
                                ₹ <%= product.price %>
                            </p>


                        <% } else { %>


                            <h4 class="text-lg font-semibold">
                                ₹ <%= product.price %>
                            </h4>


                        <% } %>


                    </div>


                </div>

            </div>


            <% }) %>


        </div>




        <!-- Price Breakdown -->

        <div class="w-[40%] border rounded-lg p-6 shadow">


            <h3 class="text-xl font-semibold mb-5">
                Price Breakdown
            </h3>


            <div class="space-y-3">


                <div class="flex justify-between">

                    <span>
                        Total MRP
                    </span>

                    <span>
                        ₹ <%= totalMRP %>
                    </span>

                </div>



                <div class="flex justify-between">


                    <span>
                        Discount on MRP
                    </span>


                    <span class="text-green-600">
                        - ₹ <%= totalDiscount %>
                    </span>


                </div>



                <div class="flex justify-between">


                    <span>
                        Platform Fee
                    </span>


                    <span>
                        ₹ <%= platformFee %>
                    </span>


                </div>



                <div class="flex justify-between">


                    <span>
                        Shipping Fee
                    </span>


                    <span class="text-green-600">
                        FREE
                    </span>


                </div>


            </div>



            <hr class="my-5">



            <div class="flex justify-between text-xl font-bold">


                <span>
                    Total Amount
                </span>


                <span class="text-green-600">

                    ₹ <%= totalAmount %>

                </span>


            </div>



            <button
                class="w-full mt-6 bg-blue-500 hover:bg-blue-600 text-white py-3 rounded">


                Proceed to Checkout


            </button>



        </div>



        <% } else { %>



        <!-- Empty Cart -->


        <div class="w-full flex flex-col items-center justify-center min-h-[60vh]">


            <h2 class="text-3xl font-semibold mb-3">

                Your Cart is Empty

            </h2>



            <p class="text-gray-500 mb-5">

                Add some products to continue shopping.

            </p>



            <a
                href="/shop"
                class="bg-blue-500 text-white px-5 py-3 rounded hover:bg-blue-600">


                Continue Shopping


            </a>


        </div>



        <% } %>


    </div>

</div>


<%- include('../partials/footer') %>
