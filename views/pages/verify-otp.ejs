<%- include('../partials/header') %>

<% if (error && error.length > 0) { %>
    <div class="absolute top-20 left-1/2 -translate-x-1/2 p-3 rounded-md bg-red-500 shadow-lg">
        <span class="text-white font-medium">
            <%= error[0] %>
        </span>
    </div>
<% } %>

<% if (success && success.length > 0) { %>
    <div class="absolute top-20 left-1/2 -translate-x-1/2 p-3 rounded-md bg-green-500 shadow-lg">
        <span class="text-white font-medium">
            <%= success[0] %>
        </span>
    </div>
<% } %>

<div class="w-full min-h-screen flex items-center justify-center bg-gray-100 px-4">
    <div class="w-full max-w-md bg-white shadow-md rounded-lg p-8">
        <h1 class="text-2xl font-bold mb-2 text-center">
            Verify your email
        </h1>

        <p class="text-gray-600 text-center mb-6">
            Enter the 6-digit OTP sent to <%= email %>
        </p>

        <form action="/users/verify-otp" method="POST">
            <input
                type="hidden"
                name="email"
                value="<%= email %>">

            <input
                class="bg-zinc-100 block w-full px-3 py-2 border rounded-md mb-4 border-zinc-200 text-center tracking-widest"
                type="text"
                name="otp"
                placeholder="Enter OTP"
                maxlength="6"
                required>

            <button
                class="w-full px-5 rounded-full py-3 bg-blue-500 text-white cursor-pointer hover:bg-blue-600"
                type="submit">
                Verify OTP
            </button>
        </form>

        <form action="/users/resend-otp" method="POST" class="mt-4 text-center">
            <input
                type="hidden"
                name="email"
                value="<%= email %>">

            <button
                class="text-blue-600 hover:text-blue-800"
                type="submit">
                Resend OTP
            </button>
        </form>
    </div>
</div>

<%- include('../partials/footer') %>

